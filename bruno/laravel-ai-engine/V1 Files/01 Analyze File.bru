meta {
  name: Analyze File
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/ai/files/analyze
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

headers {
  Accept: application/json
}

body:multipart-form {
  file: @file({{filePath}})
  message: summarize
  session_id: {{agentSessionId}}
  use_rag: true
}
