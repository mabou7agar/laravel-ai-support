meta {
  name: Start
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/data-collector/start
  body: json
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

headers {
  Accept: application/json
}

body:json {
  {
    "config_name": "{{configName}}",
    "session_id": "{{dataCollectorSessionId}}",
    "initial_data": {}
  }
}
