meta {
  name: Analyze File
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/v1/data-collector/analyze-file
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

headers {
  Accept: application/json
}

body:multipart-form {
  file: @file({{filePath}})
  session_id: {{dataCollectorSessionId}}
  fields: ["full_name","email"]
}
