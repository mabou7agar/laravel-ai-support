meta {
  name: Execute All
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/v1/actions/execute-all
  body: json
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

headers {
  Accept: application/json
}

body:json {
  {
    "action_type": "{{actionType}}",
    "data": {
      "scope": "all"
    },
    "parallel": true,
    "node_ids": ["node-1", "node-2"],
    "session_id": "{{chatSessionId}}"
  }
}
