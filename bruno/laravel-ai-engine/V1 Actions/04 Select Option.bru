meta {
  name: Select Option
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/v1/actions/select-option
  body: json
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

headers {
  Accept: application/json
}

body:json {
  {
    "option_number": 1,
    "session_id": "{{chatSessionId}}",
    "source_index": 0,
    "sources": []
  }
}
