meta {
  name: Execute Remote
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/actions/execute-remote
  body: json
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

headers {
  Accept: application/json
}

body:json {
  {
    "node": "{{actionNode}}",
    "action_type": "{{actionType}}",
    "data": {
      "model_id": 1,
      "model_class": "App\\Models\\User"
    },
    "session_id": "{{chatSessionId}}"
  }
}
