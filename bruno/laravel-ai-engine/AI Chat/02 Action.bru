meta {
  name: Action
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/ai-chat/action
  body: json
}

headers {
  Accept: application/json
  X-CSRF-TOKEN: {{csrfToken}}
  Cookie: {{webCookie}}
}

body:json {
  {
    "action_type": "{{actionType}}",
    "data": {
      "model_id": 1,
      "model_class": "App\\Models\\User"
    },
    "session_id": "{{chatSessionId}}"
  }
}
