meta {
  name: Action
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/ai-demo/chat/action
  body: json
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

headers {
  Accept: application/json
}

body:json {
  {
    "action_type": "{{actionType}}",
    "data": {
      "model_id": 1,
      "model_class": "App\\Models\\User"
    },
    "session_id": "{{chatSessionId}}"
  }
}
