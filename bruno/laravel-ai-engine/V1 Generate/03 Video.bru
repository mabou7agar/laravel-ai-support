meta {
  name: Video
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/v1/ai/generate/video
  body: json
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

headers {
  Accept: application/json
}

body:json {
  {
    "prompt": "A slow cinematic pan across a modern office",
    "duration": 5,
    "aspect_ratio": "16:9",
    "async": true
  }
}
