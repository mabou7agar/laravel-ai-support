meta {
  name: Text
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/ai/generate/text
  body: json
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

headers {
  Accept: application/json
}

body:json {
  {
    "prompt": "Write a short product description",
    "preference": "speed"
  }
}
