meta {
  name: Create Policy
  type: http
  seq: 13
}

post {
  url: {{baseUrl}}/ai-engine/admin/policies/create
  body: json
}

headers {
  Accept: application/json
  X-CSRF-TOKEN: {{csrfToken}}
  Cookie: {{webCookie}}
}

body:json {
  {
    "policy_key": "decision",
    "name": "Default Policy",
    "template": "You are an autonomous RAG decision policy. Prefer precise retrieval when the user asks for factual answers.",
    "status": "draft",
    "rollout_percentage": 0
  }
}
